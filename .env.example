# 本番ドメインの絶対URL（metadataBase・OGP 用）。Vercel 等では環境変数に設定してください。
# 例: https://www.example.com
NEXT_PUBLIC_SITE_URL=

# 関係者専用ページのアクセスコード（例: selene-2026-staff）
NEXT_PUBLIC_STAFF_ACCESS_CODE=123456

# Instagram 公式埋め込み（任意）。/p/・/reel/・/tv/ の投稿URLをカンマ区切りで指定するとサイト内に埋め込み表示されます。
# プロフィールURLだけでは埋め込み不可のため、リンクカード表示になります。
# 本番ではビルド時固定を避けるため、NEXT_PUBLIC_ または INSTAGRAM_EMBED_URLS のどちらかに同じ内容を設定可能です。
# 例: NEXT_PUBLIC_INSTAGRAM_EMBED_URLS=https://www.instagram.com/p/AbCd123/,https://www.instagram.com/reel/XyZ789/
NEXT_PUBLIC_INSTAGRAM_EMBED_URLS=
# INSTAGRAM_EMBED_URLS=

# 関係者ページから Vercel Web Analytics を開くための URL（任意）。
# Vercel ダッシュボードで該当プロジェクト → Analytics を開き、ブラウザのアドレスバーの URL を貼り付け。
# 例: https://vercel.com/your-team/your-project/analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_URL=
