# 本番ドメインの絶対URL（metadataBase・OGP 用）。Vercel 等では環境変数に設定してください。
# 例: https://www.example.com
NEXT_PUBLIC_SITE_URL=

# 関係者専用ページのアクセスコード（例: selene-2026-staff）
NEXT_PUBLIC_STAFF_ACCESS_CODE=123456

# Instagram 公式埋め込み（任意）。公開投稿のURLをカンマ区切りで複数指定すると、サイト内に埋め込み表示されます。
# 例: NEXT_PUBLIC_INSTAGRAM_EMBED_URLS=https://www.instagram.com/p/AbCdEfGh/,https://www.instagram.com/reel/XyZ123/
NEXT_PUBLIC_INSTAGRAM_EMBED_URLS=
