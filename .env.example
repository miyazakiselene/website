# 本番ドメインの絶対URL（metadataBase・OGP 用）。Vercel 等では環境変数に設定してください。
# 例: https://www.example.com
NEXT_PUBLIC_SITE_URL=

# 関係者専用ページのアクセスコード（例: selene-2026-staff）
NEXT_PUBLIC_STAFF_ACCESS_CODE=123456

# /admin/team-images 用の管理者アクセスコード（未設定時は NEXT_PUBLIC_STAFF_ACCESS_CODE を使用）
ADMIN_ACCESS_CODE=123456

# Vercel Blob の読み書きトークン
BLOB_READ_WRITE_TOKEN=

# Instagram 公式埋め込み用。投稿またはリールURLをカンマ区切りで指定してください。
# プロフィールURL全体は埋め込めないため、/p/ または /reel/ のURLを入れます。
# 例: NEXT_PUBLIC_INSTAGRAM_EMBED_URLS=https://www.instagram.com/p/AbCd123/,https://www.instagram.com/reel/XyZ789/
NEXT_PUBLIC_INSTAGRAM_EMBED_URLS=
# INSTAGRAM_EMBED_URLS=

# Supabase（本番でお知らせ・活動記録・試合結果・チーム紹介画像・ダッシュボード用レポート・更新ログを DB/Storage に置く場合）
# マイグレーション: supabase/migrations/ 配下の SQL を適用してください（team-gallery バケット含む）。
# プロジェクト URL（Project Settings → API）
NEXT_PUBLIC_SUPABASE_URL=
# Publishable キー（ブラウザに載る）
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用（上記データの読み書きに使用。RLS をバイパスするため絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=
